{
  "name": "@daretofish/marine-data-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone worker that processes queued DareToFish launch-site bathymetry/contour generation jobs: clips a bathymetry source to a launch site's coverage polygon, produces PMTiles, uploads to Cloudflare R2, and writes results back to Supabase.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "worker": "tsx src/cli/run.ts",
    "worker:once": "tsx src/cli/runOnce.ts",
    "worker:drain": "tsx src/cli/drain.ts",
    "worker:check-force-run": "tsx src/cli/checkForceRun.ts",
    "worker:import-grid": "tsx src/cli/importGrid.ts",
    "worker:queue": "tsx src/cli/queue.ts",
    "worker:requeue-generated": "tsx src/cli/requeueGenerated.ts",
    "worker:retry": "tsx src/cli/retry.ts",
    "worker:cleanup-cache": "tsx src/cli/cleanupCache.ts",
    "structures:import": "tsx src/cli/importStructures.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli/run.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.637.0",
    "@supabase/supabase-js": "^2.45.4",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.15",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}

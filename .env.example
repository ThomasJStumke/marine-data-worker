# Supabase (same project the DareToFish app uses) — service role key is
# required because the worker claims/updates jobs and writes launch_locations
# results directly, bypassing RLS's authenticated-user policies.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_PUBLIC=daretofish-public
# Public base URL tiles are served from (CDN/custom domain in front of the bucket)
R2_PUBLIC_BASE_URL=https://r2.daretofish.com

# Bathymetry provider selection — see src/providers/registry.ts. Additional
# providers can be registered without changing any other worker code.
BATHYMETRY_PROVIDER=gebco
# Base URL for the GEBCO grid-extract API used by GEBCOProvider. Kept
# configurable (not hardcoded) so a self-hosted mirror or a different
# provider endpoint can be swapped in via env alone.
GEBCO_API_BASE_URL=https://www.gebco.net/data_and_products/gebco_web_services/web_map_service/mapserv
GEBCO_GRID_VERSION=gebco_2024

# Path (inside the container) to a locally-downloaded global GEBCO grid file
# (e.g. GEBCO_2024_sub_ice_topo.nc, ~7GB, from
# https://dap.ceda.ac.uk/bodc/gebco/global/gebco_2024/sub_ice_topography_bathymetry/netcdf/).
# When set, GEBCOProvider clips straight out of this file instead of calling
# GEBCO's web service (GEBCO_API_BASE_URL) — see docs/marine-data-worker.md.
# Leave empty to use the (currently retired/404ing) remote endpoint.
GEBCO_LOCAL_GRID_PATH=

# Local working/cache directories (mounted as a persistent volume in
# production so the source cache survives worker restarts/redeploys)
CACHE_DIRECTORY=/var/lib/marine-data-worker/cache
WORK_DIRECTORY=/var/lib/marine-data-worker/work

# Concurrency + polling
MAX_CONCURRENT_JOBS=2
POLL_INTERVAL_MS=10000

# Tiling
CONTOUR_INTERVAL_M=10
MIN_ZOOM=8
MAX_ZOOM=14

# Padding added around a job's requested bbox before downloading source data,
# so the cached extent is more likely to fully cover nearby future launch
# sites (see docs/marine-data-worker.md "Source cache" section).
SOURCE_DOWNLOAD_PADDING_KM=10

# Marine Structure Platform — OSM/OpenSeaMap importer (Phase 1). Public
# Overpass API, no credentials required.
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
OVERPASS_TIMEOUT_SEC=60
OVERPASS_MAX_RETRIES=4
OVERPASS_CACHE_TTL_MS=86400000
# Delay between cells during `structures:import -- --global` (world-grid
# sweep) — keeps the public Overpass instance from being hammered by
# hundreds of sequential requests.
OVERPASS_REQUEST_DELAY_MS=3000

LOG_LEVEL=info
